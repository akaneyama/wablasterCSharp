<Window x:Class="BlastWhats.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BlastWhats"
        mc:Ignorable="d"
        Title="ProgressWindow" Height="200" Width="800" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowStyle="None" ShowInTaskbar="False">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="StatusTextBlock" Text="Mempersiapkan pengiriman..." FontSize="14" HorizontalAlignment="Center"/>
            <ProgressBar x:Name="MainProgressBar" Height="25" Margin="0,10,0,0"/>

            <Button x:Name="CancelButton" Content="Batal" Width="100" HorizontalAlignment="Center" Margin="0,15,0,0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
