<Window x:Class="BlastWhats.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BlastWhats"
        mc:Ignorable="d"
        Title="WA Blaster Kampoeng IT" Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5" WindowStyle="ThreeDBorderWindow" WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="SideMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D1E8E2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="15,5"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" 
                                              HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#128C7E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#054C44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
            <Setter Property="Foreground" Value="#FFD2D2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="8" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="White" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" Color="#C1C9D2" Opacity="0.5" BlurRadius="20"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#075E54" CornerRadius="15,0,0,15">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,30,0,20">
                            <Border Width="60" Height="60" Background="#128C7E" CornerRadius="30" Margin="0,0,0,15">
                                <TextBlock Text="🚀" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0"/>
                            </Border>

                            <TextBlock Text="WA Blaster" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="v1.1" Foreground="#A2D6C6" FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,0"/>

                            <Border Height="1" Background="#128C7E" Margin="25,25,25,10"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                            <Button x:Name="keluarBlast" Click="ExitMenu_Click" Style="{StaticResource ExitButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🚪" Margin="0,0,15,0" FontSize="18"/>
                                    <TextBlock Text="Keluar Aplikasi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Top">
                            <Button x:Name="BtnScan" Click="BtnScan_Click" Style="{StaticResource SideMenuButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📱" Margin="0,0,15,0" FontSize="18"/>
                                    <TextBlock Text="Koneksi WhatsApp" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnBlast" Click="BtnBlast_Click" Style="{StaticResource SideMenuButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✉️" Margin="0,0,15,0" FontSize="18"/>
                                    <TextBlock Text="Kirim Pesan (Blast)" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="0,15,15,0">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>