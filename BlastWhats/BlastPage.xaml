<Page x:Class="BlastWhats.BlastPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlastWhats"
      mc:Ignorable="d" 
      d:DesignHeight="1600" d:DesignWidth="800"
      Title="BlastPage" Loaded="Page_Loaded"
      Background="#F0F2F5">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" Color="#E0E0E0" Opacity="0.8" BlurRadius="10"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#128C7E"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
    </Page.Resources>

    <Grid Margin="15" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" MinWidth="400"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>


        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="10">
        <StackPanel Grid.Column="0" Margin="0,0,15,0">

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="1. Unggah Data"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="BtnUploadExcel" Content="Pilih File Excel" Click="BtnUploadExcel_Click" Width="150" Margin="10,0,0,0" Style="{StaticResource MenuButtonStyle}" />
                        <TextBlock x:Name="FilePathText" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#555" Text="Belum ada file." TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="2. Atur Pesan &amp; Pengiriman"/>

                    <TextBlock Text="Isi Pesan:" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="MessageTextBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                             BorderBrush="#CCC" BorderThickness="1" Padding="10" FontSize="14" Height="150"
                             Text="Halo {Nama}, ini adalah pesan tes untuk nomor {Nomor WA}."/>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Variabel Tersedia:" Style="{StaticResource LabelStyle}"/>
                            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="3" Background="White" Height="80">
                                <ListBox x:Name="VariablesListBox" Margin="5" Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Kolom Nomor WA:" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="PhoneNumberColumnComboBox" Padding="5" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="BtnStartBlast" Content="Mulai Blast WA" Click="BtnStartBlast_Click" Style="{StaticResource MenuButtonStyle}" Margin="0,20,0,0" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource CardTitleStyle}" Text="Log Pengiriman" Margin="0,10,0,105" Grid.RowSpan="2"/>
                    <StackPanel Grid.Row="1" Margin="0,40,0,10">
                        <TextBlock Text="Filter dari tanggal:" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="StartDatePicker" Margin="0,0,0,5"/>
                        <TextBlock Text="Sampai tanggal:" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="EndDatePicker"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,10">
                        <Button x:Name="BtnFilter" Content="🔍 Filter" Click="BtnFilter_Click" Width="100"/>
                        <Button x:Name="BtnRefreshLogs" Content="🔄 Tampilkan Semua" Click="BtnRefreshLogs_Click" Margin="5,0,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="3" Margin="0,20,0,0" x:Name="LogDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"  ScrollViewer.VerticalScrollBarVisibility="Auto"
              ScrollViewer.HorizontalScrollBarVisibility="Auto" MaxHeight="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Waktu" Binding="{Binding Timestamp, StringFormat='HH:mm:ss dd/MM/yy'}" Width="*"/>
                            <DataGridTextColumn Header="Nomor" Binding="{Binding RecipientNumber}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </StackPanel>

        </ScrollViewer>
        
        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource CardTitleStyle}" Text="3. Pratinjau Data"/>
                <DataGrid Grid.Row="1" Margin="0,10,0,0" x:Name="ExcelDataGrid" AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"
                          HorizontalGridLinesBrush="#DDD" VerticalGridLinesBrush="#DDD" Background="White"
                          BorderBrush="#CCC" BorderThickness="1">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#075E54"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,5"/>
                        </Style>
                    </DataGrid.Resources>
                </DataGrid>
            </Grid>
        </Border>
        
    </Grid>

</Page>