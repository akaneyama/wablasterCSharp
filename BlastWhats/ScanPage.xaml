<Page x:Class="BlastWhats.ScanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlastWhats"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="ScanPage"
      Background="#F0F2F5">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="40,30"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" Color="#D1D5DB" Opacity="0.6" BlurRadius="15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Border Style="{StaticResource CardBorderStyle}" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                MinWidth="450">

            <StackPanel>
                <TextBlock Text="Koneksi WhatsApp" 
                           FontSize="26" FontWeight="Bold" 
                           TextAlignment="Center" Foreground="#128C7E" 
                           Margin="0,0,0,5"/>

                <TextBlock Text="1. Buka WhatsApp di HP Anda&#x0a;2. Ketuk Menu (⋮) dan pilih Perangkat Tertaut&#x0a;3. Arahkan kamera ke layar ini" 
                           FontSize="14" Foreground="#555555" 
                           TextAlignment="Center" LineHeight="22"
                           Margin="0,0,0,25"/>

                <Border BorderBrush="#EAEAEA" BorderThickness="1" CornerRadius="8" 
                        Background="White" Width="280" Height="280"
                        HorizontalAlignment="Center">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📷" FontSize="40" TextAlignment="Center" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                            <TextBlock Text="Menunggu QR Code..." 
                                       FontSize="16" Foreground="#AAAAAA" TextAlignment="Center"/>
                        </StackPanel>

                        <Image x:Name="QrCodeImage" Width="260" Height="260" Stretch="Uniform"/>
                    </Grid>
                </Border>

                <Border Background="#F8F9FA" CornerRadius="6" Padding="15,10" Margin="0,25,0,25">
                    <TextBlock x:Name="StatusText" 
                               Text="Server belum aktif. Klik tombol di bawah untuk memulai." 
                               TextWrapping="Wrap" TextAlignment="Center" 
                               FontSize="14" FontWeight="SemiBold" 
                               Foreground="#333333"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnStartServer" Content="🚀 Mulai / Restart Server" 
                            Click="BtnStartServer_Click" 
                            Style="{StaticResource MenuButtonStyle}" 
                            Width="190" Height="40" FontSize="14"/>

                    <Button x:Name="BtnStopServer" Content="🛑 Hentikan Server" 
                            Click="BtnStopServer_Click" 
                            Style="{StaticResource DangerButtonStyle}" 
                            Width="160" Height="40" Margin="15,0,0,0" FontSize="14"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>